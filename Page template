<div class="bg-inverse">
                    <!-- LOGO PICTURE -->
  <img src="img/logo.jpg" alt="Logo"><h3 class="display-4 text-white">Police station Login Page</h3>
</div>


                     <!-- NAVBAR WITH RESPONSIVE TOGGLE -->



                     <!--  NAVIGATION SECTION  -->
  <nav class="navbar navbar-light navbar-toggleable-md bg-inverse">
    <div class="container">
      
          <button class="navbar-toggler navbar-toggler-center button-success bg-white" type="button" data-toggle="collapse" data-target="#navbarNav"><span class="navbar-toggler-icon toggler-icon-white"></span></button>
      
          <div class="collapse navbar-collapse" id="navbarNav">
          
              <ul class="navbar-nav">
                  <li class="nav-item mr-4">
                      <a class="text-white" href="#">Home</a>
                  </li>
                  <li class="nav-item mr-4">
                      <a class="text-white" href="#">Cases</a>
                  </li>
                  <li class="nav-item mr-4">
                      <a class="text-white" href="#">Services</a>
                  </li>
                  <li class="nav-item mr-4">
                      <a class="text-white" href="#">More</a>
                  </li>
              </ul>
          
          </div>
                            <!--  SEARCH SECTION  -->
          <form class="form-inline">
            <input type="text" class="form-control mr-2" placeholder="Search"> </input>
            <button class="btn btn-outline-warning">Search</button>
          </form>
        </div>
    
  </nav>
  <br><br>
        
  </div>
                        <!--  Drop-Down SECTION  -->
  <div class="container">
    <div class="row">
      <div class="col-md-3">
        <div class="dropdown">
          <button class="btn btn-success btn-block dropdown-toggle" type="button" data-toggle="dropdown">
              OPTIONS
          </button>
          <div class="dropdown-menu">
              <a class="dropdown-item" href="#">Option 1</a>
              <a class="dropdown-item" href="#">Option 2</a>
              <a class="dropdown-item" href="#">Option 3</a>
          </div>
        </div>
      </div>
    </div>
  </div>
<br><br>
                        <!--  GENDER CHOICE SECTION  -->
      <form>
        <div class="form-group form-inline">
            <label for="gender" class="mr-2">Gender</label>
            <select class="form-control mr-2" id="gender">
            <option>Male</option>
            <option>Female</option>
            </select>
        </div>
      </form>  
    
                        <!--  MAIN SECTION  -->
  <div id="main">
                        <!-- INLINE FORM -->
    <form class="form-inline">
      <input type="text" id="username" class="form-control mr-2" placeholder="Username">
      <input type="text" id="password" class="form-control mr-2" placeholder="Password">

                        <!-- Check-Box FORM -->
      <div class="form-check">
          <label class="form-check-label mr-2">
              <input type="checkbox" class="form-check-input"> Remember me
          </label>
      </div>

                        <!-- Radio FORM -->
      <div class="form-check">
      <label class="form-check-label mr-2">
        <input type="radio" value="option1" class="form-check-input">
        Agree
      </label>

      <button class="btn btn-secondary mr-2" type="submit">Submit</button>
  </form>

  <br><br>

  </div>
                        <!-- File Input -->
  <div class="form-group">
    <label for="file">Attach File</label>
    <input type="file" class="form-control-file" id="file">
    <small class="form-text text-muted" id="fileHelp">Attach PDF if Possible</small>
  </div>

                          <!--  FOOTER SECTION  -->






  <nav class="navbar navbar-light navbar-toggleable-md bg-inverse">
